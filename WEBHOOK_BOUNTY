local StartTime = tick()

task.spawn(function()
    while task.wait(0.3) do
        local current = bounty_stat.Value

        if current ~= last_bounty then
            local diff = current - last_bounty
            local prefix = diff > 0 and "+" or ""

            Stats.Earned += diff
            if diff > 0 then Stats.Kills += 1 end

            send_notif("BOUNTY UPDATE", prefix..diff, diff > 0 and 65280 or 16711680)

            last_bounty = current
            Save()
        end

        local fps = math.floor(1/RunService.RenderStepped:Wait())
        local ping = 0
        pcall(function()
            ping = math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())
        end)

        BountyLbl.Text = "💎 BOUNTY: "..FormatNumber(current)
        EarnedLbl.Text = "📈 EARNED: "..FormatNumber(Stats.Earned)
        KillsLbl.Text = "⚔️ KILLS: "..Stats.Kills
        FPSLbl.Text = "🚀 FPS: "..fps
        PingLbl.Text = "📶 PING: "..ping.."ms"

        local t = tick() - StartTime
        TimeLbl.Text = string.format("🕒 TIME: %02d:%02d:%02d", t/3600%24, t/60%60, t%60)
    end
end)
